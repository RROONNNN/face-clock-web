{
  "eslint.workingDirectories": [
    {
      "directory": "./backend",
      "changeProcessCWD": true
    },
    {
      "directory": "./frontend",
      "changeProcessCWD": true
    }
  ],
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  }
}